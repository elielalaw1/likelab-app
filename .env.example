EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Used by signup-creator edge function as `origin` for email verification links.
# Fallback order in app code:
# 1) EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN
# 2) EXPO_PUBLIC_WEB_URL
# 3) https://likelab.se (final hard fallback)
EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=https://staging.likelab.se

# Optional legacy fallback used if EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN is missing.
EXPO_PUBLIC_WEB_URL=https://staging.likelab.se
